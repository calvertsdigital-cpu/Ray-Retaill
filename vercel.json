{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "dist",
  "installCommand": "",
  "framework": null,
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|webp|ico|woff|woff2|ttf|eot|gif|map))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}